LUSTRE_TOKEN=replace-with-a-long-random-token
LUSTRE_BIND=127.0.0.1
LUSTRE_PORT=8787
LUSTRE_DB_PATH=./data/lustrestudio.db
LUSTRE_DOWNLOAD_ROOT=./downloads
LUSTRE_CONCURRENCY=2
LUSTRE_BROWSER_FALLBACK=true
LUSTRE_VERIFICATION_TIMEOUT_MS=600000
# Comma-separated aliases are configuration, not a hard-coded hostname list.
LUSTRE_PROVIDER_ALIASES={"dood":"doodstream.com","mixdrop":"mixdrop.co"}
